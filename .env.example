# Copy to .env and fill in. NEVER commit the real .env.

# --- Model providers ---
ANTHROPIC_API_KEY=sk-ant-...        # console.anthropic.com  (generation)
VOYAGE_API_KEY=pa-...               # voyageai.com  (embeddings + reranker)

# --- API auth (machine-to-machine key the UI/clients send as X-API-Key) ---
API_KEY=hk_generate_a_long_random_string

# --- Retrieval store ---
# qdrant = local on-disk files (dev);  pg = pgvector over DATABASE_URL (prod)
ENGINE=qdrant
# Required only when ENGINE=pg. Format:
# postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=

# --- Optional tuning (sensible defaults if omitted) ---
RATE_LIMIT=10                       # max requests per key per window
RATE_WINDOW=60                      # window length in seconds
# Comma-separated origins allowed to call the API from a browser.
# Add your public URL in production, e.g. https://your-app.onrender.com
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
